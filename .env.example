FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=

FIRECRAWL_API_KEY=your-firecrawl-api-key
FIRECRAWL_API_URL=https://api.firecrawl.dev/v1/scrape
FIRECRAWL_PAGE_SIZE=50
FIRECRAWL_SCRAPE_URL=
JOB_SOURCE_1=https://remoteok.com/remote-dev-jobs
JOB_SOURCE_2=https://weworkremotely.com/remote-jobs/search?term=developer
JOB_SOURCE_3=https://remotive.com/remote-jobs/software-dev
JOB_SOURCE_4=https://wellfound.com/jobs
FIRESTORE_COLLECTION_JOBS=jobs

GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Distributed rate limiting for Vercel production deployments.
# Use either the Upstash names below or the Vercel KV aliases.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

NODE_ENV=development
